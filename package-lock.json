{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user-specific settings and profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique ID of the user." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "displayName": { "type": "string", "description": "The user's display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to the user's profile picture." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "The user's role in the system." },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user profile was created." }
      },
      "required": ["uid", "email", "role"]
    },
    "Client": {
      "title": "Client",
      "description": "A client record in the chamber.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "fileCode": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "address": { "type": "string" },
        "ownerUid": { "type": "string" }
      },
      "required": ["name", "fileCode", "ownerUid"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "A financial transaction record.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "client": { "type": "string" },
        "ownerUid": { "type": "string" }
      },
      "required": ["date", "description", "amount", "type", "ownerUid"]
    },
    "Invoice": {
      "title": "Invoice",
      "description": "A billing invoice.",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"] },
        "dueDate": { "type": "string", "format": "date" },
        "issueDate": { "type": "string", "format": "date" },
        "ownerUid": { "type": "string" }
      },
      "required": ["clientName", "amount", "status", "dueDate", "issueDate", "ownerUid"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "A calendar appointment.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "client": { "type": "string" },
        "type": { "type": "string", "enum": ["hearing", "consultation", "meeting"] },
        "location": { "type": "string" },
        "ownerUid": { "type": "string" }
      },
      "required": ["title", "date", "time", "type", "ownerUid"]
    },
    "Analysis": {
      "title": "Legal Research",
      "description": "AI-generated document analysis and research results.",
      "type": "object",
      "properties": {
        "fileName": { "type": "string" },
        "fileSize": { "type": "string" },
        "summary": { "type": "string" },
        "keyPoints": { "type": "array", "items": { "type": "string" } },
        "risks": { "type": "array", "items": { "type": "string" } },
        "recommendations": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["completed", "failed"] },
        "timestamp": { "type": "number" },
        "ownerUid": { "type": "string" }
      },
      "required": ["fileName", "summary", "status", "timestamp", "ownerUid"]
    },
    "Case": {
      "title": "Legal Case",
      "description": "A legal case record.",
      "type": "object",
      "properties": {
        "caseNumber": { "type": "string" },
        "courtName": { "type": "string" },
        "clientName": { "type": "string" },
        "petitioner": { "type": "string" },
        "respondent": { "type": "string" },
        "nextDate": { "type": "string", "format": "date" },
        "lastOrder": { "type": "string" },
        "status": { "type": "string" },
        "ownerUid": { "type": "string" }
      },
      "required": ["caseNumber", "courtName", "ownerUid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles collection."
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Clients collection."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Transactions collection."
    },
    "/invoices/{invoiceId}": {
      "schema": "Invoice",
      "description": "Invoices collection."
    },
    "/appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointments collection."
    },
    "/analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "Document analyses collection."
    },
    "/cases/{caseId}": {
      "schema": "Case",
      "description": "Legal cases collection."
    }
  }
}
